<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="16.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="labirynth.gui.GravityLabyrinthController"
      style="-fx-background-color: #1a1a2e;">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>

        <VBox alignment="CENTER" spacing="4.0">
            <Label text="Gravity Labyrinth"
                   style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #c8d6f8; -fx-font-family: 'Segoe UI';" />
            <Label text="Gördítsd a golyót a célmezőre a lehető legkevesebb lépéssel!"
                   style="-fx-font-size: 13; -fx-text-fill: #8892b0;" />
        </VBox>

        <GridPane fx:id="board" hgap="6.0" vgap="6.0" alignment="CENTER"
                  prefHeight="350.0" prefWidth="350.0"
                  style="-fx-background-color: #0f3460; -fx-padding: 8; -fx-background-radius: 10;">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="44.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="44.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="44.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="44.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="44.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="44.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="44.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="44.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="44.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="44.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="44.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="44.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="44.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="44.0" vgrow="SOMETIMES" />
            </rowConstraints>
        </GridPane>

        <HBox alignment="CENTER" spacing="10.0">
            <Label fx:id="numberOfMovesLabel" text="Lépések:"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #c8d6f8;" />
            <TextField fx:id="numberOfMovesField" alignment="CENTER" editable="false"
                       focusTraversable="false" mouseTransparent="true"
                       prefColumnCount="4" text="0"
                       style="-fx-font-size: 18; -fx-background-color: #0f3460; -fx-text-fill: #e0e8ff;
                              -fx-border-color: #4a6fa5; -fx-border-radius: 6; -fx-background-radius: 6;" />
        </HBox>

        <GridPane alignment="CENTER" hgap="6.0" vgap="6.0">
            <Button fx:id="upButton" text="▲" onAction="#onUpButton"
                    GridPane.columnIndex="1" GridPane.rowIndex="0"
                    prefWidth="60" prefHeight="60"
                    style="-fx-font-size: 22; -fx-background-color: #4a6fa5; -fx-text-fill: white;
                           -fx-background-radius: 8; -fx-cursor: hand;" />
            <Button fx:id="leftButton" text="◄" onAction="#onLeftButton"
                    GridPane.columnIndex="0" GridPane.rowIndex="1"
                    prefWidth="60" prefHeight="60"
                    style="-fx-font-size: 22; -fx-background-color: #4a6fa5; -fx-text-fill: white;
                           -fx-background-radius: 8; -fx-cursor: hand;" />
            <Button fx:id="rightButton" text="►" onAction="#onRightButton"
                    GridPane.columnIndex="2" GridPane.rowIndex="1"
                    prefWidth="60" prefHeight="60"
                    style="-fx-font-size: 22; -fx-background-color: #4a6fa5; -fx-text-fill: white;
                           -fx-background-radius: 8; -fx-cursor: hand;" />
            <Button fx:id="downButton" text="▼" onAction="#onDownButton"
                    GridPane.columnIndex="1" GridPane.rowIndex="2"
                    prefWidth="60" prefHeight="60"
                    style="-fx-font-size: 22; -fx-background-color: #4a6fa5; -fx-text-fill: white;
                           -fx-background-radius: 8; -fx-cursor: hand;" />
        </GridPane>

    </children>
</VBox>
